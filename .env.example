# Deployment configuration — copy to .env and fill in values
REMOTE_HOST=user@hostname
GCP_CREDENTIALS_PATH=$HOME/.gcp/your-service-account.json
GCP_PROJECT_ID=your-gcp-project-id
DEPLOY_IP=your.server.ip.address

# Optional overrides
# REMOTE_APP_DIR=/home/user/apps/poker-tutor
# HOST_PORT=8080
# GCP_REGION=us-central1
# AI_MODEL=gemini-3.1-flash-lite-preview
# MAX_AI_CALLS_PER_GAME=200
# MAX_CONCURRENT_GAMES=15
# MAX_COACHING_PER_HAND=3
